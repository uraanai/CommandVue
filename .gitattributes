# Normalize text files to LF on commit; check out native to the OS.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary

# SVG is text.
*.svg text

# Lockfiles are generated — hide from language stats and PR diffs by default.
*.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true
