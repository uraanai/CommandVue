{
  "id": "command-center-light",
  "name": "Command Center Light",
  "description": "Operations-console aesthetic inspired by Bloomberg / Anduril Lattice. Compact, sharp corners, teal interactive accent, amber warnings. Mono font for the data layer.",
  "author": "CommandVue",
  "mode": "light",
  "density": "compact",
  "tokens": {
    "color-surface-base": "var(--color-slate-100)",
    "color-surface-raised": "#ffffff",
    "color-surface-overlay": "#ffffff",
    "color-surface-sunken": "var(--color-slate-200)",
    "color-border-subtle": "var(--color-slate-200)",
    "color-border-default": "var(--color-slate-300)",
    "color-border-strong": "var(--color-slate-400)",
    "color-text-primary": "var(--color-slate-900)",
    "color-text-secondary": "var(--color-slate-700)",
    "color-text-tertiary": "var(--color-slate-500)",
    "color-text-disabled": "var(--color-slate-400)",
    "color-text-inverse": "var(--color-slate-50)",
    "color-interactive": "var(--color-teal-700)",
    "color-interactive-hover": "var(--color-teal-600)",
    "color-interactive-active": "var(--color-teal-800)",
    "color-interactive-subtle": "var(--color-teal-50)",
    "color-on-interactive": "#ffffff",
    "color-status-success": "var(--color-green-700)",
    "color-status-success-subtle": "var(--color-green-50)",
    "color-status-warning": "var(--color-amber-700)",
    "color-status-warning-subtle": "var(--color-amber-50)",
    "color-status-danger": "var(--color-red-700)",
    "color-status-danger-subtle": "var(--color-red-50)",
    "color-status-info": "var(--color-teal-700)",
    "color-status-info-subtle": "var(--color-teal-50)",
    "color-focus-ring": "var(--color-teal-500)",
    "color-surface": "var(--color-slate-100)",
    "color-foreground": "var(--color-slate-900)",
    "color-muted": "var(--color-slate-700)",
    "color-faint": "var(--color-slate-500)",
    "color-border": "var(--color-slate-300)",
    "datatable-header-bg": "var(--color-slate-200)",
    "datatable-row-hover-bg": "var(--color-teal-50)",
    "datatable-font-size": "0.75rem",
    "dialog-backdrop": "rgb(15 23 42 / 0.45)",
    "tooltip-bg": "var(--color-slate-900)",
    "tooltip-text": "var(--color-slate-50)",
    "radius-md": "0.125rem",
    "radius-lg": "0.25rem",
    "font-family-body": "var(--font-family-mono)"
  }
}
