{
  "id": "command-center-dark",
  "name": "Command Center Dark",
  "description": "Dark operations-console aesthetic. Deep navy surfaces, teal interactive accent, amber alerts. Sharp corners, dense rows, mono data layer. The reference theme for 24/7 ops rooms.",
  "author": "CommandVue",
  "mode": "dark",
  "density": "compact",
  "tokens": {
    "color-surface-base": "var(--color-slate-950)",
    "color-surface-raised": "var(--color-slate-900)",
    "color-surface-overlay": "var(--color-slate-900)",
    "color-surface-sunken": "#040712",
    "color-border-subtle": "var(--color-slate-800)",
    "color-border-default": "var(--color-slate-700)",
    "color-border-strong": "var(--color-slate-600)",
    "color-text-primary": "var(--color-slate-50)",
    "color-text-secondary": "var(--color-slate-300)",
    "color-text-tertiary": "var(--color-slate-500)",
    "color-text-disabled": "var(--color-slate-600)",
    "color-text-inverse": "var(--color-slate-900)",
    "color-interactive": "var(--color-teal-300)",
    "color-interactive-hover": "var(--color-teal-200)",
    "color-interactive-active": "var(--color-teal-400)",
    "color-interactive-subtle": "var(--color-teal-950)",
    "color-on-interactive": "var(--color-slate-950)",
    "color-status-success": "var(--color-green-400)",
    "color-status-success-subtle": "var(--color-green-950)",
    "color-status-warning": "var(--color-amber-400)",
    "color-status-warning-subtle": "var(--color-amber-950)",
    "color-status-danger": "var(--color-red-400)",
    "color-status-danger-subtle": "var(--color-red-950)",
    "color-status-info": "var(--color-teal-300)",
    "color-status-info-subtle": "var(--color-teal-950)",
    "color-focus-ring": "var(--color-teal-400)",
    "color-surface": "var(--color-slate-950)",
    "color-foreground": "var(--color-slate-50)",
    "color-muted": "var(--color-slate-300)",
    "color-faint": "var(--color-slate-500)",
    "color-border": "var(--color-slate-700)",
    "datatable-header-bg": "var(--color-slate-900)",
    "datatable-row-hover-bg": "var(--color-teal-950)",
    "datatable-font-size": "0.75rem",
    "dialog-backdrop": "rgb(0 0 0 / 0.75)",
    "tooltip-bg": "var(--color-slate-50)",
    "tooltip-text": "var(--color-slate-900)",
    "radius-md": "0.125rem",
    "radius-lg": "0.25rem",
    "font-family-body": "var(--font-family-mono)"
  }
}
