{
  "id": "admin-panel-light",
  "name": "Admin Panel Light",
  "description": "Comfortable, approachable admin aesthetic. Generous spacing, soft violet accent, friendly status colors. Best for management dashboards and content surfaces rather than dense data.",
  "author": "CommandVue",
  "mode": "light",
  "density": "comfortable",
  "tokens": {
    "color-surface-base": "var(--color-slate-50)",
    "color-surface-raised": "#ffffff",
    "color-surface-overlay": "#ffffff",
    "color-surface-sunken": "var(--color-slate-100)",
    "color-border-subtle": "var(--color-slate-100)",
    "color-border-default": "var(--color-slate-200)",
    "color-border-strong": "var(--color-slate-300)",
    "color-text-primary": "var(--color-slate-800)",
    "color-text-secondary": "var(--color-slate-600)",
    "color-text-tertiary": "var(--color-slate-500)",
    "color-text-disabled": "var(--color-slate-400)",
    "color-text-inverse": "var(--color-slate-50)",
    "color-interactive": "var(--color-violet-600)",
    "color-interactive-hover": "var(--color-violet-500)",
    "color-interactive-active": "var(--color-violet-700)",
    "color-interactive-subtle": "var(--color-violet-50)",
    "color-on-interactive": "#ffffff",
    "color-status-success": "var(--color-green-600)",
    "color-status-success-subtle": "var(--color-green-50)",
    "color-status-warning": "var(--color-amber-500)",
    "color-status-warning-subtle": "var(--color-amber-50)",
    "color-status-danger": "var(--color-red-500)",
    "color-status-danger-subtle": "var(--color-red-50)",
    "color-status-info": "var(--color-violet-500)",
    "color-status-info-subtle": "var(--color-violet-50)",
    "color-focus-ring": "var(--color-violet-500)",
    "color-surface": "var(--color-slate-50)",
    "color-foreground": "var(--color-slate-800)",
    "color-muted": "var(--color-slate-600)",
    "color-faint": "var(--color-slate-500)",
    "color-border": "var(--color-slate-200)",
    "datatable-header-bg": "#ffffff",
    "datatable-row-hover-bg": "var(--color-violet-50)",
    "dialog-backdrop": "rgb(15 23 42 / 0.4)",
    "tooltip-bg": "var(--color-slate-800)",
    "tooltip-text": "var(--color-slate-50)",
    "radius-md": "0.5rem",
    "radius-lg": "0.75rem"
  }
}
