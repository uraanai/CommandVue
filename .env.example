# CommandVue environment variables.
#
# This file is COMMITTED to the repository as a documented template.
# To override locally, copy it to `.env.local` (which is git-ignored).
# Never commit real secrets — use a secrets manager (Vault, AWS Secrets
# Manager, GitHub Actions secrets) for production values.
#
# Only variables prefixed with VITE_ are exposed to the browser.

# Application display name (shown in the TitleBar and browser tab).
VITE_APP_NAME="CommandVue"

# Telemetry WebSocket endpoint used by TelemetryPanel.
# The default points at a public echo server so the demo works out of the box.
# Override with your own backend WS URL for production deployments.
VITE_WS_URL="wss://echo.websocket.events"

# Default map center (decimal degrees) and zoom for Cesium and MapLibre panels.
VITE_DEFAULT_MAP_CENTER_LAT=30.0
VITE_DEFAULT_MAP_CENTER_LON=70.0
VITE_DEFAULT_MAP_ZOOM=4
